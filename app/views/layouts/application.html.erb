<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for(:title) || "セリフさん | VTuber・ライバーのためのセリフ生成AI" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="セリフ枠配信のVTuber・ライバーさん向け。ジャンルとテーマを入れるだけで、AIがキャラに合ったセリフを10個提案します。無料で使えます。">
    <meta name="keywords" content="セリフさん,セリフ枠,セリフ生成,VTuber,Vライバー,配信,AI,REALITY,ツンデレ,恋愛ボイス,ファンタジー,日常,コメディ">
    <meta name="robots" content="index, follow">

    <%# OGP %>
    <meta property="og:title" content="セリフさん | VTuber・ライバーのためのセリフ生成AI">
    <meta property="og:description" content="セリフ枠配信のVTuber・ライバーさん向け。ジャンルとテーマを入れるだけで、AIがキャラに合ったセリフを10個提案します。無料で使えます。">
    <meta property="og:type" content="website">
    <meta property="og:image" content="/ogp.png">
    <meta property="og:site_name" content="セリフさん">
    <meta property="og:locale" content="ja_JP">

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="セリフさん | VTuber・ライバーのためのセリフ生成AI">
    <meta name="twitter:description" content="セリフ枠配信のVTuber・ライバーさん向け。ジャンルとテーマを入れるだけで、AIがキャラに合ったセリフを10個提案します。無料で使えます。">
    <meta name="twitter:image" content="/ogp.png">

    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="セリフさん">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#FAFAF8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="logged-in" content="<%= logged_in? %>">

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <%# Google Identity Services（Firebase Auth の認証トークン取得に利用） %>
    <script src="https://accounts.google.com/gsi/client" async defer></script>

    <%# Google Analytics (GA4) — 本番環境のみ出力（ローカルは計測しない） %>
    <% if Rails.env.production? && ENV['GA_MEASUREMENT_ID'].present? %>
      <script async src="https://www.googletagmanager.com/gtag/js?id=<%= ENV['GA_MEASUREMENT_ID'] %>"></script>
      <%= javascript_tag nonce: true do %>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '<%= j ENV['GA_MEASUREMENT_ID'] %>');
      <% end %>
    <% end %>
  </head>

  <body class="min-h-screen bg-[#F2F0ED] text-[#1F1F1F]">
    <main class="max-w-md mx-auto min-h-screen bg-[#FAFAF8] flex flex-col border-[1.5px] border-[#E0DDD9] md:my-5 md:rounded-lg overflow-hidden relative">
      <% flash.each do |type, msg| %>
        <div class="px-4 py-2.5 text-xs border-b border-[#E0DDD9] bg-[#F0EFEC] text-[#555555]">
          <%= msg %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <%# ===== 生成中ローディングオーバーレイ（紙とペン） ===== %>
    <div id="loading-overlay" class="hidden fixed inset-0 bg-[#F2F0ED]/80 z-50 items-center justify-center backdrop-blur-sm flex">
      <div class="bg-[#FAFAF8] rounded-lg px-8 py-10 flex flex-col items-center gap-7 border-[1.5px] border-[#E0DDD9] max-w-xs">
        <div class="w-[120px] h-[120px]">
          <svg viewBox="0 0 120 120" fill="none" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full">
            <rect x="15" y="25" width="80" height="70" rx="4" fill="#FAFAF8" stroke="#C8C4B8" stroke-width="1.2"/>
            <path d="M25 45 L 70 45" stroke="#D4D0CB" stroke-width="1.2"/>
            <path d="M25 58 L 80 58" stroke="#D4D0CB" stroke-width="1.2"/>
            <path class="scribble-line" d="M25 72 Q 40 70, 55 72 T 80 72" stroke="#5B5BD6" stroke-width="1.6" fill="none"/>
            <g class="pen-group">
              <path d="M70 40 L 95 15 L 102 22 L 77 47 Z" fill="#FAFAF8" stroke="#1F1F1F" stroke-width="1.3"/>
              <path d="M70 40 L 67 50 L 77 47 Z" fill="#5B5BD6" stroke="#1F1F1F" stroke-width="1.3"/>
              <path d="M88 22 L 95 29" stroke="#1F1F1F" stroke-width="1.3"/>
            </g>
          </svg>
        </div>
        <div class="flex gap-2.5">
          <span class="w-1.5 h-1.5 rounded-full bg-[#5B5BD6] pen-dot"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-[#5B5BD6] pen-dot" style="animation-delay:0.18s"></span>
          <span class="w-1.5 h-1.5 rounded-full bg-[#5B5BD6] pen-dot" style="animation-delay:0.36s"></span>
        </div>
        <div class="flex flex-col items-center gap-3">
          <span class="wavy-underline text-[15px] font-semibold text-[#555555] tracking-wide">セリフを考えているよ</span>
          <span class="text-[12px] text-[#888888] font-mono tracking-wider">writing for you…</span>
        </div>
      </div>
    </div>
  </body>
</html>
