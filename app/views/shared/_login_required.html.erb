<%#
  Required local:
    message: String — 未ログイン時の説明文
%>
<div class="flex-1 flex flex-col items-center justify-center px-6 py-10 text-center">
  <div class="text-5xl mb-4">🔒</div>
  <p class="text-sm text-[#1F1F1F] font-bold mb-2">ログインが必要です</p>
  <p class="text-xs text-[#888888] mb-6 leading-relaxed"><%= message %></p>
  <div data-gis-button class="flex justify-center">
    <span class="text-xs text-[#5B5BD6] font-bold">ログインする</span>
  </div>
</div>
