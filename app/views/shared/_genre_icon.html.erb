<%#
  Required local:
    slug: String — Genre slug (romance / tsundere / fantasy / daily / comedy / random)
  Optional local:
    size: Integer — viewBox基準のpx指定（既定はw-fullで親スパンに従う）
%>
<% case slug
   when 'romance' %>
<svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M11 18 C 3 12, 3 5, 7.5 5 C 9.5 5, 11 7, 11 7 C 11 7, 12.5 5, 14.5 5 C 19 5, 19 12, 11 18 Z"/></svg>
<% when 'tsundere' %>
<svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="11" cy="11" r="7"/><path d="M8 9 L 8.5 10"/><path d="M14 9 L 13.5 10"/><path d="M7.5 14 Q 11 12, 14.5 14"/></svg>
<% when 'fantasy' %>
<svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M4 18 L 11 4 L 18 18 Z"/><path d="M8 13 L 14 13"/><circle cx="11" cy="9" r="0.8" fill="currentColor"/></svg>
<% when 'daily' %>
<svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="11" cy="11" r="4"/><path d="M11 2 L 11 4"/><path d="M11 18 L 11 20"/><path d="M2 11 L 4 11"/><path d="M18 11 L 20 11"/><path d="M4.5 4.5 L 6 6"/><path d="M16 16 L 17.5 17.5"/><path d="M17.5 4.5 L 16 6"/><path d="M6 16 L 4.5 17.5"/></svg>
<% when 'comedy' %>
<svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="11" cy="11" r="7"/><path d="M7 8 Q 8 7, 9 8"/><path d="M13 8 Q 14 7, 15 8"/><path d="M7 13 Q 11 17, 15 13"/></svg>
<% when 'random' %>
<svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="4" y="4" width="14" height="14" rx="2"/><circle cx="8" cy="8" r="0.8" fill="currentColor"/><circle cx="14" cy="8" r="0.8" fill="currentColor"/><circle cx="11" cy="11" r="0.8" fill="currentColor"/><circle cx="8" cy="14" r="0.8" fill="currentColor"/><circle cx="14" cy="14" r="0.8" fill="currentColor"/></svg>
<% end %>
