<% content_for :title, 'お問い合わせ' %>

<header class="px-5 pt-8 pb-4 border-b border-[#E0DDD9] flex-shrink-0">
  <h1 class="wavy-underline text-[20px] font-bold">お問い合わせ</h1>
</header>

<div class="flex-1 overflow-y-auto px-5 pt-5 pb-24">
  <% if @contact.errors.any? %>
    <div class="bg-[#F0EFEC] border border-[#E0DDD9] text-[#555555] text-xs rounded-lg px-4 py-2.5 mb-4">
      <% @contact.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @contact, url: contact_path, class: 'flex flex-col gap-5' do |f| %>
    <div>
      <label class="block text-[11px] font-bold text-[#555555] mb-1.5 tracking-wide">
        お名前 <span class="text-[#5B5BD6]">*</span>
      </label>
      <%= f.text_field :name,
          placeholder: 'ニックネームでもOK',
          class: 'w-full px-3.5 py-3 border border-[#E0DDD9] rounded-lg text-sm bg-[#FAFAF8] focus:border-[#5B5BD6] focus:outline-none placeholder:text-[#BBBBBB]',
          maxlength: 50 %>
    </div>

    <div>
      <label class="block text-[11px] font-bold text-[#555555] mb-1.5 tracking-wide">
        メールアドレス
        <span class="font-normal text-[#888888]">任意</span>
      </label>
      <%= f.email_field :email,
          placeholder: 'example@mail.com',
          class: 'w-full px-3.5 py-3 border border-[#E0DDD9] rounded-lg text-sm bg-[#FAFAF8] focus:border-[#5B5BD6] focus:outline-none placeholder:text-[#BBBBBB]',
          maxlength: 254 %>
    </div>

    <div>
      <label class="block text-[11px] font-bold text-[#555555] mb-1.5 tracking-wide">
        お問い合わせ内容 <span class="text-[#5B5BD6]">*</span>
      </label>
      <%= f.text_area :body,
          placeholder: 'ご意見・ご感想・不具合報告など',
          rows: 6,
          class: 'w-full px-3.5 py-3 border border-[#E0DDD9] rounded-lg text-sm bg-[#FAFAF8] focus:border-[#5B5BD6] focus:outline-none placeholder:text-[#BBBBBB] resize-none leading-relaxed',
          maxlength: 2000 %>
    </div>

    <%= f.submit '送信する',
        class: 'w-full py-3.5 bg-[#5B5BD6] text-white rounded-lg text-[15px] font-bold tracking-[1px] -rotate-[0.8deg] hover:rotate-0 transition-transform cursor-pointer' %>
  <% end %>
</div>

<%= render 'shared/bottom_nav', active: :about %>
