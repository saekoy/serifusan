<% content_for :title, 'お問い合わせ' %>

<header class="px-4 py-3 border-b border-[#E0DDD9] flex-shrink-0">
  <h1 class="text-base font-bold">お問い合わせ</h1>
</header>

<div class="flex-1 overflow-y-auto px-4 py-5">
  <% if @contact.errors.any? %>
    <div class="bg-[#FEF2F2] border border-[#FCA5A5] text-[#991B1B] text-xs rounded-lg px-4 py-2.5 mb-4">
      <% @contact.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: @contact, url: contact_path, class: 'flex flex-col gap-4' do |f| %>
    <div>
      <label class="block text-xs font-semibold text-[#555555] mb-1">お名前</label>
      <%= f.text_field :name,
          placeholder: 'ニックネームでもOK',
          class: 'w-full border border-[#E0DDD9] rounded-lg px-3 py-2.5 text-sm bg-white focus:outline-none focus:border-[#5B5BD6]',
          maxlength: 50 %>
    </div>

    <div>
      <label class="block text-xs font-semibold text-[#555555] mb-1">メールアドレス</label>
      <%= f.email_field :email,
          placeholder: 'example@mail.com',
          class: 'w-full border border-[#E0DDD9] rounded-lg px-3 py-2.5 text-sm bg-white focus:outline-none focus:border-[#5B5BD6]',
          maxlength: 254 %>
    </div>

    <div>
      <label class="block text-xs font-semibold text-[#555555] mb-1">お問い合わせ内容</label>
      <%= f.text_area :body,
          placeholder: 'ご意見・ご感想・不具合報告など',
          rows: 6,
          class: 'w-full border border-[#E0DDD9] rounded-lg px-3 py-2.5 text-sm bg-white focus:outline-none focus:border-[#5B5BD6] resize-none',
          maxlength: 2000 %>
    </div>

    <div>
      <%= f.submit '送信する',
          class: 'w-full bg-[#5B5BD6] text-white text-sm font-bold rounded-lg py-3 cursor-pointer hover:opacity-90' %>
    </div>
  <% end %>
</div>

<%= render 'shared/bottom_nav', active: :about %>
