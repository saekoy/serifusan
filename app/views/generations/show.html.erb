<% content_for :title, 'セリフ一覧 - セリフさん' %>

<%# ===== 結果ヘッダー ===== %>
<header class="flex items-center justify-between px-5 pt-7 pb-4 border-b border-[#E0DDD9] flex-shrink-0">
  <h1 class="wavy-underline text-[20px] font-bold tracking-wide">セリフ一覧</h1>
  <% if @genre %>
    <span class="text-[11px] font-bold text-[#5B5BD6] bg-[#FAFAF8] border border-[#5B5BD6] px-2.5 py-0.5 rounded-lg -rotate-1 inline-flex items-center gap-1">
      <span class="w-3 h-3"><%= render 'shared/genre_icon', slug: @genre[:slug] %></span>
      <%= @genre[:name] %>
    </span>
  <% end %>
</header>

<%# ===== 未ログイン時: ログイン誘導バナー ===== %>
<% unless @logged_in %>
  <div class="bg-[#F0EFEC] border-b border-[#E0DDD9] px-4 py-2.5 text-xs text-[#555555] flex items-center gap-2 flex-shrink-0">
    <svg viewBox="0 0 14 14" fill="none" stroke="#5B5BD6" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 flex-shrink-0">
      <rect x="3" y="6.5" width="8" height="5.5" rx="0.8"/>
      <path d="M4.5 6.5 V 4 C 4.5 2.5, 5.6 1.5, 7 1.5 C 8.4 1.5, 9.5 2.5, 9.5 4 V 6.5"/>
    </svg>
    いいねの保存にはログインが必要です
  </div>
<% end %>

<%# ===== セリフ一覧 ===== %>
<div class="flex-1 px-[18px] py-4 pb-[140px] overflow-y-auto">
  <ul class="flex flex-col gap-2">
    <% @serifus.each_with_index do |serifu, i| %>
      <li class="bg-[#FAFAF8] border border-[#E0DDD9] rounded-lg p-3.5 flex flex-col gap-2.5 hover:border-[#C8C4B8]">
        <div class="flex items-start gap-2.5">
          <span class="font-mono text-[11px] font-bold text-[#888888] min-w-[22px] pt-1 tracking-wider">
            <%= format('%02d', i + 1) %>
          </span>
          <p class="flex-1 text-sm leading-[1.7] text-[#1F1F1F]"><%= serifu %></p>
        </div>
        <div class="flex justify-end gap-1.5">
          <% if @logged_in %>
            <% if @saved_serifus.include?(serifu) %>
              <span class="h-7 px-3 inline-flex items-center gap-1 text-[12px] text-[#5B5BD6] border-[1.5px] border-[#5B5BD6] rounded-lg bg-[#FAFAF8]">
                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><path d="M3 1.5 H 9 V 10.5 L 6 8.5 L 3 10.5 Z" fill="currentColor" opacity="0.15"/><path d="M3 1.5 H 9 V 10.5 L 6 8.5 L 3 10.5 Z"/></svg>
                いいね済み
              </span>
            <% else %>
              <%= button_to '/favorites',
                            params: { serifu: serifu, genre: @generation['genre'] },
                            form_class: 'inline',
                            class: 'h-7 px-3 inline-flex items-center gap-1 text-[12px] text-[#555555] border border-[#E0DDD9] rounded-lg bg-[#FAFAF8] hover:border-[#C8C4B8] cursor-pointer' do %>
                <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><path d="M3 1.5 H 9 V 10.5 L 6 8.5 L 3 10.5 Z"/></svg>
                いいね
              <% end %>
            <% end %>
          <% end %>
          <button type="button"
                  class="h-7 px-3 inline-flex items-center gap-1 text-[12px] text-[#555555] border border-[#E0DDD9] rounded-lg bg-[#FAFAF8] hover:border-[#C8C4B8] cursor-pointer"
                  data-serifu="<%= serifu %>">
            <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-3 h-3"><rect x="3" y="3" width="7" height="7" rx="1"/><path d="M3 6 H 2 V 2 H 7 V 3"/></svg>
            コピー
          </button>
        </div>
      </li>
    <% end %>
  </ul>
</div>

<%# ===== アクションフッター（ボトムナビの上） ===== %>
<div class="fixed bottom-[60px] left-0 right-0 max-w-md mx-auto px-4 pt-3 pb-3 flex gap-2 z-30 bg-gradient-to-t from-[#FAFAF8] from-80% to-transparent">
  <%= link_to root_path,
              class: 'flex-1 py-3 inline-flex items-center justify-center gap-1.5 bg-[#FAFAF8] border border-[#E0DDD9] text-[#1F1F1F] text-sm font-semibold rounded-lg rotate-[0.6deg] hover:rotate-0 transition-transform' do %>
    <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M3 7 L 3 4 Q 3 2, 5 2 L 10 2 Q 12 2, 12 4 L 12 10 Q 12 12, 10 12 L 7 12"/><path d="M5 5 L 2 7 L 5 9"/></svg>
    もう一回
  <% end %>
  <a href="https://twitter.com/intent/tweet?text=<%= CGI.escape("セリフさんで生成したセリフ\n#セリフさん") %>"
     target="_blank" rel="noopener"
     class="flex-1 py-3 inline-flex items-center justify-center gap-1.5 bg-black text-white text-sm font-bold rounded-lg -rotate-[0.6deg] hover:rotate-0 transition-transform">
    <span class="font-bold">𝕏</span>
    シェア
  </a>
</div>

<%= render 'shared/bottom_nav', active: :home %>
