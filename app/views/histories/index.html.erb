<% content_for :title, '履歴' %>

<header class="flex items-center justify-between px-4 py-3 border-b border-[#E0DDD9] flex-shrink-0">
  <h1 class="text-base font-bold">🕐 生成履歴</h1>
  <% if @logged_in && @generations.any? %>
    <span class="text-xs text-[#888888]"><%= @generations.size %>件</span>
  <% end %>
</header>

<% if @logged_in %>
  <div class="flex gap-1.5 overflow-x-auto px-4 pt-3 pb-1 flex-shrink-0">
    <%= link_to 'すべて', histories_path,
                class: "text-xs px-3 py-1 rounded-full border whitespace-nowrap #{@genre_filter.nil? ? 'bg-[#5B5BD6] text-white border-transparent' : 'bg-white text-[#B07BD4] border-[#EDD8FF]'}" %>
    <% Genre.all.each do |g| %>
      <%= link_to g[:emoji], histories_path(genre: g[:slug]),
                  title: g[:name],
                  class: "text-xs px-3 py-1 rounded-full border whitespace-nowrap #{@genre_filter == g[:slug] ? 'bg-[#5B5BD6] text-white border-transparent' : 'bg-white text-[#B07BD4] border-[#EDD8FF]'}" %>
    <% end %>
  </div>

  <% if @generations.any? %>
    <div class="flex-1 overflow-y-auto px-4 py-4 pb-24">
      <ul class="flex flex-col gap-3">
        <% @generations.each do |g| %>
          <% genre = Genre.find(g.genre) %>
          <li>
            <%= link_to result_path(id: g.id),
                        class: 'block bg-white border border-[#E0DDD9] rounded-xl p-3.5 hover:border-[#5B5BD6] transition' do %>
              <div class="flex items-center gap-2 mb-1.5">
                <% if genre %>
                  <span class="text-[14px] flex-shrink-0" aria-hidden="true"><%= genre[:emoji] %></span>
                <% end %>
                <span class="text-[12px] text-[#555555] truncate flex-1">テーマ：<%= g.theme %></span>
                <span class="text-[11px] text-[#888888] flex-shrink-0"><%= g.created_at.strftime('%Y/%-m/%-d %H:%M') %></span>
              </div>
              <div class="flex items-center justify-between text-[11px] text-[#888888]">
                <span><%= g.serifus.size %>件のセリフ</span>
                <span class="text-[#5B5BD6]">結果を開く →</span>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="flex-1 px-4 py-6 text-sm text-[#888888]">
      まだ生成履歴はありません。
    </div>
  <% end %>
<% else %>
  <%= render 'shared/login_required',
             message: '過去に生成したセリフは、ログインすると履歴から見返せます。' %>
<% end %>

<%= render 'shared/bottom_nav', active: :history %>
